{
  "versete": [
    {
      "text": "Căci atât de mult a iubit Dumnezeu lumea, că a dat pe singurul Lui Fiu, pentru ca oricine crede în El să nu piară, ci să aibă viață veșnică.",
      "reference": "Ioan 3:16",
      "book": "Ioan",
      "chapter": 3,
      "verseNumber": "16",
      "category": "dragoste",
      "tags": ["dragoste", "salvare", "credință", "viață veșnică"]
    },
    {
      "text": "Domnul este păstorul meu: nu voi duce lipsă de nimic.",
      "reference": "Psalmii 23:1",
      "book": "Psalmii",
      "chapter": 23,
      "verseNumber": "1",
      "category": "pace",
      "tags": ["pace", "încredere", "protecție", "Dumnezeu"]
    },
    {
      "text": "Încrede-te în Domnul din toată inima ta și nu te bizui pe înțelepciunea ta!",
      "reference": "Proverbe 3:5",
      "book": "Proverbe",
      "chapter": 3,
      "verseNumber": "5",
      "category": "credință",
      "tags": ["credință", "încredere", "înțelepciune"]
    },
    {
      "text": "Nu ți-am poruncit Eu: 'Întărește-te și îmbărbătează-te? Nu te înspăimânta și nu te îngrozi, căci Domnul Dumnezeul tău este cu tine oriunde vei merge.'",
      "reference": "Iosua 1:9",
      "book": "Iosua",
      "chapter": 1,
      "verseNumber": "9",
      "category": "curaj",
      "tags": ["curaj", "putere", "prezența lui Dumnezeu"]
    },
    {
      "text": "Eu sunt Calea, Adevărul și Viața. Nimeni nu vine la Tatăl decât prin Mine.",
      "reference": "Ioan 14:6",
      "book": "Ioan",
      "chapter": 14,
      "verseNumber": "6",
      "category": "credință",
      "tags": ["Isus", "adevăr", "viață", "cale"]
    },
    {
      "text": "Pace vă las, pacea Mea v-o dau. Nu v-o dau cum o dă lumea. Să nu vi se tulbure inima, nici să nu se înspăimânte.",
      "reference": "Ioan 14:27",
      "book": "Ioan",
      "chapter": 14,
      "verseNumber": "27",
      "category": "pace",
      "tags": ["pace", "liniște", "Isus", "încredere"]
    },
    {
      "text": "Toate lucrurile lucrează împreună spre binele celor ce iubesc pe Dumnezeu.",
      "reference": "Romani 8:28",
      "book": "Romani",
      "chapter": 8,
      "verseNumber": "28",
      "category": "speranță",
      "tags": ["speranță", "bine", "dragoste", "plan divin"]
    },
    {
      "text": "Și iată că Eu sunt cu voi în toate zilele, până la sfârșitul veacului.",
      "reference": "Matei 28:20",
      "book": "Matei",
      "chapter": 28,
      "verseNumber": "20",
      "category": "mângâiere",
      "tags": ["prezență", "Isus", "mângâiere", "promisiune"]
    },
    {
      "text": "Nu vă îngrijorați de nimic, ci în orice lucru aduceți cererile voastre la cunoștința lui Dumnezeu, prin rugăciuni și cereri cu mulțumiri.",
      "reference": "Filipeni 4:6",
      "book": "Filipeni",
      "chapter": 4,
      "verseNumber": "6",
      "category": "rugăciune",
      "tags": ["rugăciune", "pace", "încredere", "mulțumire"]
    },
    {
      "text": "Veniți la Mine, toți cei trudiți și împovărați, și Eu vă voi da odihnă.",
      "reference": "Matei 11:28",
      "book": "Matei",
      "chapter": 11,
      "verseNumber": "28",
      "category": "mângâiere",
      "tags": ["odihnă", "mângâiere", "Isus", "pace"]
    },
    {
      "text": "Isus Hristos este același ieri și azi și în veci!",
      "reference": "Evrei 13:8",
      "book": "Evrei",
      "chapter": 13,
      "verseNumber": "8",
      "category": "credință",
      "tags": ["Isus", "veșnicie", "neschimbare", "credință"]
    },
    {
      "text": "Dragostea îndelung rabdă, este plină de bunătate; dragostea nu pizmuiește; dragostea nu se laudă, nu se umflă de mândrie.",
      "reference": "1 Corinteni 13:4",
      "book": "1 Corinteni",
      "chapter": 13,
      "verseNumber": "4",
      "category": "dragoste",
      "tags": ["dragoste", "răbdare", "bunătate", "smerenie"]
    },
    {
      "text": "Bucurați-vă întotdeauna. Rugați-vă neîncetat. Mulțumiți lui Dumnezeu pentru toate lucrurile.",
      "reference": "1 Tesaloniceni 5:16-18",
      "book": "1 Tesaloniceni",
      "chapter": 5,
      "verseNumber": "16-18",
      "category": "bucurie",
      "tags": ["bucurie", "rugăciune", "recunoștință"]
    },
    {
      "text": "Fiindcă atât de mult ne iubește Dumnezeu, trebuie și noi să ne iubim unii pe alții.",
      "reference": "1 Ioan 4:11",

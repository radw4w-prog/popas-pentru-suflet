# ═══════════════════════════════════════
# AI PROVIDERS — Multi-provider setup
# ═══════════════════════════════════════

# OpenRouter (PRINCIPAL) — 15+ modele free cu o cheie
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxx

# Mistral AI — Cea mai bună calitate pentru română
MISTRAL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# Cerebras — Cel mai rapid (1M tokens/zi gratis)
CEREBRAS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# Hugging Face — Model românesc RoLlama3
HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxx

# Groq (deja îl ai)
GROQ_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# Gemini (deja îl ai)
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# ═══════════════════════════════════════
# APP
# ═══════════════════════════════════════
NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/popas_suflet
JWT_SECRET=your-super-secret-jwt-key-change-this